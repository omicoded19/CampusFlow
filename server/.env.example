PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5433/campusflow?schema=public"

JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# One shared staff account created by npm run db:seed.
# This account can operate every campus service queue.
DEMO_STAFF_EMAIL="staff@campusflow.local"
DEMO_STAFF_PASSWORD="replace-with-a-strong-demo-password"

# Optional local demo admin account with analytics dashboard
DEMO_ADMIN_EMAIL="admin@campusflow.local"
DEMO_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
